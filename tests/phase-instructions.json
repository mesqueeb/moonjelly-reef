          "SLICE_NUMBER = $ISSUE_ID",
          "SLICE_BRANCH = {from slice body}",
          "BASE_BRANCH = {from slice/plan body}",
          "TARGET_BRANCH = {from slice/plan body}",
          "WORKTREE_PATH = ../worktree-$SLICE_NAME-inspect"
        ]
      },
      {
        "op": "enter",
        "cmd": "worktree-enter.sh --fork-from $SLICE_BRANCH --path $WORKTREE_PATH"
      },
      { "op": "phase-specific" },
      {
        "op": "commit-code",
        "cmd": "commit.sh --branch $SLICE_BRANCH -m \"inspect: cleanup\"",
        "optional": true
      },
      {
        "op": "update-tracker",
        "tracker-local": [
          "worktree-enter.sh --fork-from $TARGET_BRANCH --path $WORKTREE_PATH",
          "mv \"[to-inspect]\" \"[to-merge]\" or \"[to-rework]\"",
          "commit.sh --branch $TARGET_BRANCH -m \"inspect: update tracker for $SLICE_NAME\"",
          "worktree-exit.sh --path $WORKTREE_PATH"
        ],
        "tracker-github-pass": "gh issue edit $SLICE_NUMBER --remove-label to-inspect --add-label to-merge",
        "tracker-github-fail": "gh issue edit $SLICE_NUMBER --remove-label to-inspect --add-label to-rework"
      },
      {
        "op": "exit",
        "cmd": "worktree-exit.sh --path $WORKTREE_PATH"

      {
        "op": "commit-code",
        "cmd": "commit.sh --branch $SLICE_BRANCH -m \"inspect: cleanup\"",
        "if": "cleanup-needed"
      },
      {
        "op": "update-tracker",
        "tracker-local-gitignored": "mv \"$TRACKER_PATH/$PLAN_ID $PLAN_TITLE/slices/[to-inspect] $SLICE_NAME.md\" \"$TRACKER_PATH/$PLAN_ID $PLAN_TITLE/slices/[to-merge] or [to-rework] $SLICE_NAME.md\"",
        "tracker-local-committed": [
          "worktree-enter.sh --fork-from $TRACKER_BRANCH --path $WORKTREE_PATH-tracker",
          "mv \"$TRACKER_PATH/$PLAN_ID $PLAN_TITLE/slices/[to-inspect] $SLICE_NAME.md\" \"$TRACKER_PATH/$PLAN_ID $PLAN_TITLE/slices/[to-merge] or [to-rework] $SLICE_NAME.md\"",
          "commit.sh --branch $TRACKER_BRANCH -m \"inspect: update tracker for $SLICE_NAME\"",
          "worktree-exit.sh --path $WORKTREE_PATH-tracker"
        ],
        "tracker-github-pass": "gh issue edit $SLICE_NUMBER --remove-label to-inspect --add-label to-merge",
        "tracker-github-fail": "gh issue edit $SLICE_NUMBER --remove-label to-inspect --add-label to-rework"
      },
      {
        "op": "exit",
        "cmd": "worktree-exit.sh --path $WORKTREE_PATH"
      }
    ],

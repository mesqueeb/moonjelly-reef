{
  "$comment": [
    "Source of truth for what each phase .md file should contain.",
    "Each phase is an ordered array of operations.",
    "The test runner checks: (1) each command string exists in the .md file, (2) they appear in this order.",
    "optional: true means the operation may be skipped at runtime (but the code block must still be in the .md).",
    "",
    "Operations:",
    "  fetch-context        — read the plan or slice before starting. tracker-github = gh issue view, tracker-local = read file at path",
    "  set-variables        — documents which variables this skill/phase produces for downstream consumers",
    "  enter                — worktree-enter.sh --fork-from $BRANCH --path $WORKTREE_PATH",
    "  phase-specific       — represents phase specific sections",
    "  create-remote-branch — git push -u origin ... (slice only)",
    "  commit-code          — commit.sh --branch $SLICE_BRANCH (PR flow)",
    "  pr-create            — gh pr create",
    "  pr-merge             — gh pr merge",
    "  update-pr-body       — rewrite PR description",
    "  update-tracker       — tracker-github = gh issue edit/close, tracker-local = full worktree cycle (enter, file ops, commit, exit)",
    "  exit                 — worktree-exit.sh --path $WORKTREE_PATH"
  ],
  "skills": {
    "reef-scope": [
      {
        "op": "set-variables",
        "sh": [
          "ISSUE_ID = {issue-id} # pre-existing and passed or generate",
          "LOCAL_PATH = {local-path} # set only if defined at .agents/moonjelly-reef/config.md"
        ]
      },
      {
        "op": "fetch-context",
        "tracker-github": "gh issue view $ISSUE_ID --json body,title,labels",
        "tracker-local": "$LOCAL_PATH/$ISSUE_ID */[to-scope] plan.md"
      },
      { "op": "phase-specific" },
      {
        "op": "set-variables",
        "sh": [
          "PLAN_ID = $ISSUE_ID",
          "PLAN_TITLE = {plan-title} # as per discussion context",
          "BASE_BRANCH = {base-branch} # as per discussion context",
          "TARGET_BRANCH = {target-branch} # as per discussion context",
          "PLAN_CONTENT = {plan-content} # as per discussion context",
          "WORKTREE_PATH = ../worktree-$PLAN_ID-scope"
        ]
      },
      {
        "op": "update-tracker",
        "tracker-github": "gh issue edit $PLAN_ID --body \"$PLAN_CONTENT\" --remove-label to-scope --add-label to-slice",
        "tracker-local": [
          "worktree-enter.sh --fork-from $BASE_BRANCH --path $WORKTREE_PATH",
          "mv \"$LOCAL_PATH/$PLAN_ID [to-scope] plan.md\" \"$LOCAL_PATH/$PLAN_ID [to-slice] $PLAN_TITLE.md\"",
          "printf '%s' \"$PLAN_CONTENT\" > \"$LOCAL_PATH/$PLAN_ID [to-slice] $PLAN_TITLE.md\"",
          "commit.sh --branch $BASE_BRANCH -m \"scope: persist plan for $PLAN_ID $PLAN_TITLE\"",
          "worktree-exit.sh --path $WORKTREE_PATH"
        ]
      }
    ]
  },
  "phases": {
    "slice.md": [
      {
        "op": "set-variables",
        "sh": [
          "ISSUE_ID = {issue-id} # pre-existing and passed or generate",
          "LOCAL_PATH = {local-path} # set only if defined at .agents/moonjelly-reef/config.md"
        ]
      },
      {
        "op": "fetch-context",
        "tracker-github": "gh issue view $ISSUE_ID --json body,title,labels",
        "tracker-local": "$LOCAL_PATH/$ISSUE_ID */[to-slice] plan.md"
      },
      {
        "op": "set-variables",
        "sh": [
          "PLAN_ID = $ISSUE_ID",
          "PLAN_TITLE = {from plan body}",
          "BASE_BRANCH = {from plan body}",
          "TARGET_BRANCH = {from plan body}",
          "WORKTREE_PATH = ../worktree-$PLAN_ID-slice"
        ]
      },
      { "op": "phase-specific" },
      {
        "op": "set-variables",
        "sh": [
          "SLICE_NAME = {per slice, e.g. 001-auth-endpoint}",
          "SLICE_NUMBER = {sub-issue number (github) or file name (local)}"
        ]
      },
      {
        "op": "enter",
        "cmd": "worktree-enter.sh --fork-from $TARGET_BRANCH --path $WORKTREE_PATH"
      },
      {
        "op": "create-remote-branch",
        "cmd": "git push -u origin $TARGET_BRANCH",
        "optional": true
      },
      {
        "op": "update-tracker",
        "tracker-github": "gh issue edit $PLAN_ID --remove-label to-slice --add-label in-progress",
        "tracker-local": [
          "worktree-enter.sh --fork-from $TARGET_BRANCH --path $WORKTREE_PATH",
          "commit.sh --branch $TARGET_BRANCH -m \"slice: create slices for $PLAN_ID $PLAN_TITLE\"",
          "worktree-exit.sh --path $WORKTREE_PATH"
        ]
      },
      {
        "op": "exit",
        "cmd": "worktree-exit.sh --path $WORKTREE_PATH"
      }
    ],
    "implement.md": [
      {
        "op": "set-variables",
        "sh": [
          "ISSUE_ID = {issue-id} # pre-existing and passed or generate",
          "LOCAL_PATH = {local-path} # set only if defined at .agents/moonjelly-reef/config.md"
        ]
      },
      {
        "op": "fetch-context",
        "tracker-github": "gh issue view $ISSUE_ID --json body,title,labels",
        "tracker-local": "$LOCAL_PATH/*/slices/[to-implement] $ISSUE_ID.md"
      },
      {
        "op": "set-variables",
        "sh": [
          "SLICE_NAME = {from slice body}",
          "SLICE_NUMBER = $ISSUE_ID",
          "BASE_BRANCH = {from slice/plan body}",
          "TARGET_BRANCH = {from slice/plan body}",
          "SLICE_BRANCH = {PR branch, e.g. feat/001-auth-endpoint}",
          "WORKTREE_PATH = ../worktree-$SLICE_NAME-implement"
        ]
      },
      {
        "op": "enter",
        "cmd": "worktree-enter.sh --fork-from $TARGET_BRANCH --path $WORKTREE_PATH"
      },
      { "op": "phase-specific" },
      {
        "op": "commit-code",
        "cmd": "commit.sh --branch $SLICE_BRANCH -m \"$SLICE_NAME: implementation\""
      },
      {
        "op": "pr-create",
        "cmd": "gh pr create --base $TARGET_BRANCH --title \"$SLICE_NAME\" --body \"$REPORT\""
      },
      {
        "op": "set-variables",
        "sh": ["PR_NUMBER = {from gh pr create output}"]
      },
      {
        "op": "update-tracker",
        "tracker-github": "gh issue edit $SLICE_NUMBER --remove-label to-implement --add-label to-inspect",
        "tracker-local": [
          "worktree-enter.sh --fork-from $TARGET_BRANCH --path $WORKTREE_PATH",
          "mv \"[to-implement]\" \"[to-inspect]\"",
          "commit.sh --branch $TARGET_BRANCH -m \"implement: update tracker for $SLICE_NAME\"",
          "worktree-exit.sh --path $WORKTREE_PATH"
        ]
      },
      {
        "op": "exit",
        "cmd": "worktree-exit.sh --path $WORKTREE_PATH"
      }
    ],
    "inspect.md": [
      {
        "op": "set-variables",
        "sh": [
          "ISSUE_ID = {issue-id} # pre-existing and passed or generate",
          "LOCAL_PATH = {local-path} # set only if defined at .agents/moonjelly-reef/config.md"

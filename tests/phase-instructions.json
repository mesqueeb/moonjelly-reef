{
  "$comment": [
    "Source of truth for what each skill/phase .md file should contain.",
    "Each entry is an ordered array of operations.",
    "The test runner checks: (1) each command string exists in the .md file, (2) they appear in this order.",
    "",
    "\"if\" field: the operation is conditional — it must exist in the .md but only runs when the condition holds.",
    "  e.g. \"if\": \"multi-slice\" — only for multi-slice plans",
    "",
    "Tracker commands use `tracker.sh issue ...` syntax.",
    "For GitHub: replace `tracker.sh` with `gh`.",
    "For MCP trackers (ClickUp, Jira, Linear): use equivalent MCP tool calls.",
    "",
    "Operations:",
    "  set-variables        — documents which variables this skill/phase produces",
    "  fetch-context        — tracker.sh issue view / gh issue view",
    "  enter                — worktree-enter.sh --fork-from $BRANCH --path $WORKTREE_PATH",
    "  phase-specific       — represents phase specific sections",
    "  create-remote-branch — git push -u origin ... (slice only)",
    "  commit-code          — commit.sh --branch $SLICE_BRANCH (PR flow)",
    "  pr-create            — gh pr create",
    "  pr-merge             — gh pr merge",
    "  update-pr-body       — gh pr edit",
    "  update-tracker       — tracker.sh issue edit/close",
    "  exit                 — worktree-exit.sh --path $WORKTREE_PATH"
  ],
  "skills": {
    "reef-pulse": [
      {
        "op": "set-variables",
        "sh": [
          "TRACKER_BRANCH = {from config.md} # e.g. main"
        ]
      },
      {
        "op": "checkout-tracker-branch",
        "cmd": "git fetch origin $TRACKER_BRANCH && git checkout $TRACKER_BRANCH && git pull",
        "if": "local-tracker-committed"
      },
      { "op": "phase-specific" }
    ],
    "reef-scope": [
      {
        "op": "set-variables",
        "sh": [
          "ISSUE_ID = {issue-id} # pre-existing and passed or generate"
        ]
      },
      {
        "op": "fetch-context",
        "tracker": "tracker.sh issue view $ISSUE_ID --json body,title,labels"
      },
      { "op": "phase-specific" },
      {
        "op": "set-variables",
        "sh": [
          "PLAN_ID = $ISSUE_ID",
          "PLAN_TITLE = {plan-title} # as per discussion context",
          "BASE_BRANCH = {base-branch} # as per discussion context",
          "TARGET_BRANCH = {target-branch} # as per discussion context",
          "PLAN_CONTENT = {plan-content} # as per discussion context",
          "WORKTREE_PATH = ../worktree-$PLAN_ID-scope"
        ]
      },
      {
        "op": "update-tracker",
        "tracker": "tracker.sh issue edit $PLAN_ID --body \"$PLAN_CONTENT\" --remove-label to-scope --add-label to-slice"
      }
    ]
  },
  "phases": {
    "slice.md": [
      {
        "op": "set-variables",
        "sh": [
          "ISSUE_ID = {issue-id} # pre-existing and passed or generate"
        ]
      },
      {
        "op": "fetch-context",
        "tracker": "tracker.sh issue view $ISSUE_ID --json body,title,labels"
      },
      {
        "op": "set-variables",
        "sh": [
          "PLAN_ID = $ISSUE_ID",
          "PLAN_TITLE = {from plan body}",
          "BASE_BRANCH = {from plan body}",
          "TARGET_BRANCH = {from plan body}",
          "WORKTREE_PATH = ../worktree-$PLAN_ID-slice"
        ]
      },
      {
        "op": "enter",
        "cmd": "worktree-enter.sh --fork-from $TARGET_BRANCH --path $WORKTREE_PATH"
      },
      {
        "op": "create-remote-branch",
        "cmd": "git push -u origin $TARGET_BRANCH",
        "if": "multi-slice"
      },
      { "op": "phase-specific" },
      {
        "op": "set-variables",
        "sh": [
          "SLICE_NAME = {per slice, e.g. 001-auth-endpoint}",
          "SLICE_NUMBER = {sub-issue number (github) or file name (local)}"
        ]
      },
      {
        "op": "update-tracker",
        "tracker": "tracker.sh issue edit $PLAN_ID --remove-label to-slice --add-label in-progress"
      },
      {
        "op": "exit",
        "cmd": "worktree-exit.sh --path $WORKTREE_PATH"
      }
    ],
    "implement.md": [
      {
        "op": "set-variables",
        "sh": [
          "ISSUE_ID = {issue-id} # pre-existing and passed or generate"
        ]
      },
      {
        "op": "fetch-context",
        "tracker": "tracker.sh issue view $ISSUE_ID --json body,title,labels"
      },
      {
        "op": "set-variables",
        "sh": [
          "SLICE_NAME = {from slice body}",
          "SLICE_NUMBER = $ISSUE_ID",
          "PLAN_ID = {from slice/plan body}",
          "PLAN_TITLE = {from slice/plan body}",
          "BASE_BRANCH = {from slice/plan body}",
          "TARGET_BRANCH = {from slice/plan body}",
          "SLICE_BRANCH = {PR branch, e.g. feat/001-auth-endpoint}",
          "WORKTREE_PATH = ../worktree-$SLICE_NAME-implement"
        ]
      },
      {
        "op": "enter",
        "cmd": "worktree-enter.sh --fork-from $TARGET_BRANCH --path $WORKTREE_PATH"
      },
      { "op": "phase-specific" },
      {
        "op": "commit-code",
        "cmd": "commit.sh --branch $SLICE_BRANCH -m \"$SLICE_NAME: implementation\""
      },
      {
        "op": "pr-create",
        "cmd": "gh pr create --base $TARGET_BRANCH --title \"$SLICE_NAME\" --body \"$REPORT\""
      },
      {
        "op": "set-variables",
        "sh": ["PR_NUMBER = {from gh pr create output}"]
      },
      {
        "op": "update-tracker",
        "tracker": "tracker.sh issue edit $SLICE_NUMBER --remove-label to-implement --add-label to-inspect"
      },
      {
        "op": "exit",
        "cmd": "worktree-exit.sh --path $WORKTREE_PATH"
      }
    ],
    "inspect.md": [
      {
        "op": "set-variables",
        "sh": [
          "ISSUE_ID = {issue-id} # pre-existing and passed or generate"
        ]
      },
      {
        "op": "fetch-context",
        "tracker": "tracker.sh issue view $ISSUE_ID --json body,title,labels"
      },
      {
        "op": "set-variables",
        "sh": [
          "SLICE_NAME = {from slice body}",
          "SLICE_NUMBER = $ISSUE_ID",
          "SLICE_BRANCH = {from slice body}",
          "PLAN_ID = {from slice/plan body}",
          "PLAN_TITLE = {from slice/plan body}",
          "BASE_BRANCH = {from slice/plan body}",
          "TARGET_BRANCH = {from slice/plan body}",
          "WORKTREE_PATH = ../worktree-$SLICE_NAME-inspect"
        ]
      },
      {
        "op": "enter",
        "cmd": "worktree-enter.sh --fork-from $SLICE_BRANCH --path $WORKTREE_PATH"
      },
      { "op": "phase-specific" },
      {
        "op": "commit-code",
        "cmd": "commit.sh --branch $SLICE_BRANCH -m \"inspect: cleanup\"",
        "if": "cleanup-needed"
      },
      {
        "op": "update-tracker",
        "tracker-pass": "tracker.sh issue edit $SLICE_NUMBER --remove-label to-inspect --add-label to-merge",
        "tracker-fail": "tracker.sh issue edit $SLICE_NUMBER --remove-label to-inspect --add-label to-rework"
      },
      {
        "op": "exit",
        "cmd": "worktree-exit.sh --path $WORKTREE_PATH"
      }
    ],
    "rework.md": [
      {
        "op": "set-variables",
        "sh": [
          "ISSUE_ID = {issue-id} # pre-existing and passed or generate"
        ]
      },
      {
        "op": "fetch-context",
        "tracker": "tracker.sh issue view $ISSUE_ID --json body,title,labels"
      },
      {
        "op": "set-variables",
        "sh": [
          "SLICE_NAME = {from slice body}",
          "SLICE_NUMBER = $ISSUE_ID",
          "SLICE_BRANCH = {from slice body}",
          "PR_NUMBER = {from slice body}",
          "PLAN_ID = {from slice/plan body}",
          "PLAN_TITLE = {from slice/plan body}",
          "BASE_BRANCH = {from slice/plan body}",
          "TARGET_BRANCH = {from slice/plan body}",
          "WORKTREE_PATH = ../worktree-$SLICE_NAME-rework"
        ]
      },
      {
        "op": "enter",
        "cmd": "worktree-enter.sh --fork-from $SLICE_BRANCH --path $WORKTREE_PATH"
      },
      { "op": "phase-specific" },
      {
        "op": "commit-code",
        "cmd": "commit.sh --branch $SLICE_BRANCH -m \"rework: address inspection feedback\""
      },
      {
        "op": "update-pr-body",
        "cmd": "gh pr edit $PR_NUMBER --body \"$REPORT\""
      },
      {
        "op": "update-tracker",
        "tracker": "tracker.sh issue edit $SLICE_NUMBER --remove-label to-rework --add-label to-inspect"
      },
      {
        "op": "exit",
        "cmd": "worktree-exit.sh --path $WORKTREE_PATH"
      }
    ],
    "await-waves.md": [
      {
        "op": "set-variables",
        "sh": [
          "ISSUE_ID = {issue-id} # pre-existing and passed or generate"
        ]
      },
      {
        "op": "fetch-context",
        "tracker": "tracker.sh issue view $ISSUE_ID --json body,title,labels"
      },
      {
        "op": "set-variables",
        "sh": [
          "SLICE_NAME = {from slice body}",
          "SLICE_NUMBER = $ISSUE_ID",
          "PLAN_ID = {from slice/plan body}",
          "PLAN_TITLE = {from slice/plan body}",
          "BASE_BRANCH = {from slice/plan body}",
          "TARGET_BRANCH = {from slice/plan body}",
          "WORKTREE_PATH = ../worktree-$SLICE_NAME-await-waves"
        ]
      },
      {
        "op": "enter",
        "cmd": "worktree-enter.sh --fork-from $TARGET_BRANCH --path $WORKTREE_PATH"
      },
      { "op": "phase-specific" },
      {
        "op": "update-tracker",
        "tracker": "tracker.sh issue edit $SLICE_NUMBER --remove-label to-await-waves --add-label to-implement"
      },
      {
        "op": "exit",
        "cmd": "worktree-exit.sh --path $WORKTREE_PATH"
      }
    ],
    "merge.md": [
      {
        "op": "set-variables",
        "sh": [
          "ISSUE_ID = {issue-id} # pre-existing and passed or generate"
        ]
      },
      {
        "op": "fetch-context",
        "tracker": "tracker.sh issue view $ISSUE_ID --json body,title,labels"
      },
      {
        "op": "set-variables",
        "sh": [
          "SLICE_NAME = {from slice body}",
          "SLICE_NUMBER = $ISSUE_ID",
          "PR_NUMBER = {from slice body}",
          "PLAN_ID = {from slice/plan body}",
          "PLAN_TITLE = {from slice/plan body}",
          "BASE_BRANCH = {from slice/plan body}",
          "TARGET_BRANCH = {from slice/plan body}",
          "WORKTREE_PATH = ../worktree-$SLICE_NAME-merge"
        ]
      },
      {
        "op": "pr-merge",
        "cmd": "gh pr merge $PR_NUMBER --squash --delete-branch"
      },
      {
        "op": "enter",
        "cmd": "worktree-enter.sh --fork-from $TARGET_BRANCH --path $WORKTREE_PATH"
      },
      { "op": "phase-specific" },
      {
        "op": "update-tracker",
        "tracker": [
          "tracker.sh issue close $SLICE_NUMBER",
          "tracker.sh issue edit $PLAN_ID --remove-label in-progress --add-label to-ratify"
        ]
      },
      {
        "op": "exit",
        "cmd": "worktree-exit.sh --path $WORKTREE_PATH"
      }
    ],
    "ratify.md": [
      {
        "op": "set-variables",
        "sh": [
          "ISSUE_ID = {issue-id} # pre-existing and passed or generate"
        ]
      },
      {
        "op": "fetch-context",
        "tracker": "tracker.sh issue view $ISSUE_ID --json body,title,labels"
      },
      {
        "op": "set-variables",
        "sh": [
          "PLAN_ID = $ISSUE_ID",
          "PLAN_TITLE = {from plan body}",
          "BASE_BRANCH = {from plan body}",
          "TARGET_BRANCH = {from plan body}",
          "WORKTREE_PATH = ../worktree-$PLAN_ID-ratify"
        ]
      },
      {
        "op": "enter",
        "cmd": "worktree-enter.sh --fork-from $TARGET_BRANCH --path $WORKTREE_PATH"
      },
      { "op": "phase-specific" },
      {
        "op": "commit-code",
        "cmd": "commit.sh --branch $TARGET_BRANCH -m \"ratify: add documentation\"",
        "if": "documentation-added"
      },
      {
        "op": "pr-create",
        "cmd": "gh pr create --base $BASE_BRANCH --head $TARGET_BRANCH --title \"$PLAN_TITLE\" --body \"$REPORT\""
      },
      {
        "op": "update-tracker",
        "tracker-pass": "tracker.sh issue edit $PLAN_ID --remove-label to-ratify --add-label to-land",
        "tracker-fail": "tracker.sh issue edit $PLAN_ID --remove-label to-ratify --add-label to-rescan"
      },
      {
        "op": "exit",
        "cmd": "worktree-exit.sh --path $WORKTREE_PATH"
      }
    ],
    "rescan.md": [
      {
        "op": "set-variables",
        "sh": [
          "ISSUE_ID = {issue-id} # pre-existing and passed or generate"
        ]
      },
      {
        "op": "fetch-context",
        "tracker": "tracker.sh issue view $ISSUE_ID --json body,title,labels"
      },
      {
        "op": "set-variables",
        "sh": [
          "PLAN_ID = $ISSUE_ID",
          "PLAN_TITLE = {from plan body}",
          "BASE_BRANCH = {from plan body}",
          "TARGET_BRANCH = {from plan body}",
          "WORKTREE_PATH = ../worktree-$PLAN_ID-rescan"
        ]
      },
      {
        "op": "enter",
        "cmd": "worktree-enter.sh --fork-from $TARGET_BRANCH --path $WORKTREE_PATH"
      },
      { "op": "phase-specific" },
      {
        "op": "update-tracker",
        "tracker": "tracker.sh issue edit $PLAN_ID --remove-label to-rescan --add-label in-progress"
      },
      {
        "op": "exit",
        "cmd": "worktree-exit.sh --path $WORKTREE_PATH"
      }
    ]
  }
}

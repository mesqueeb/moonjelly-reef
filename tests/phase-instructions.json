{
  "$comment": [
    "Source of truth for what each skill/phase .md file should contain.",
    "Each entry is an ordered array of operations.",
    "The test runner checks: (1) each command string exists in the .md file, (2) they appear in this order.",
    "",
    "\"if\" field: the operation is conditional — it must exist in the .md but only runs when the condition holds.",
    "  e.g. \"if\": \"local-tracker-committed\" — only when tracker is local-tracker-committed",
    "  e.g. \"if\": \"multi-slice\" — only for multi-slice plans",
    "",
    "Local tracker file structure:",
    "  $TRACKER_PATH/$PLAN_ID $PLAN_TITLE/[tag] plan.md",
    "  $TRACKER_PATH/$PLAN_ID $PLAN_TITLE/slices/[tag] $SLICE_NAME.md",
    "  Fetch globs use $ISSUE_ID* (no space) to match both '42/' and '42 my-feature/'",
    "",
    "Operations:",
    "  set-variables              — documents which variables this skill/phase produces",
    "  fetch-context              — read the plan or slice before starting",
    "  enter                      — worktree-enter.sh --fork-from $BRANCH --path $WORKTREE_PATH",
    "  phase-specific             — represents phase specific sections",
    "  create-remote-branch       — git push -u origin ... (slice only)",
    "  commit-code                — commit.sh --branch $SLICE_BRANCH (PR flow)",
    "  pr-create                  — gh pr create",
    "  pr-merge                   — gh pr merge",
    "  update-pr-body             — rewrite PR description",
    "  update-tracker             — per-tracker operations:",
    "    tracker-github           — gh issue edit/close",
    "    tracker-local-gitignored — file ops only (mv, printf, etc.)",
    "    tracker-local-committed  — worktree-enter $TRACKER_BRANCH → file ops → commit → worktree-exit",
    "  exit                       — worktree-exit.sh --path $WORKTREE_PATH"
  ],
  "skills": {
    "reef-pulse": [
      {
        "op": "set-variables",
        "sh": [
          "TRACKER_BRANCH = {from config.md} # e.g. main"
        ]
      },
      {
        "op": "checkout-tracker-branch",
        "cmd": "git fetch origin $TRACKER_BRANCH && git checkout $TRACKER_BRANCH && git pull",
        "if": "local-tracker-committed"
      },
      { "op": "phase-specific" }
    ],
    "reef-scope": [
      {
        "op": "set-variables",
        "sh": [
          "ISSUE_ID = {issue-id} # pre-existing and passed or generate",
          "TRACKER_PATH = {from config.md} # set only for local tracker",
          "TRACKER_BRANCH = {from config.md} # set only for local-tracker-committed"
        ]
      },
      {
        "op": "fetch-context",
        "tracker-github": "gh issue view $ISSUE_ID --json body,title,labels",
        "tracker-local": "$TRACKER_PATH/$ISSUE_ID*/[to-scope] plan.md"
      },
      { "op": "phase-specific" },
      {
        "op": "set-variables",
        "sh": [
          "PLAN_ID = $ISSUE_ID",
          "PLAN_TITLE = {plan-title} # as per discussion context",
          "BASE_BRANCH = {base-branch} # as per discussion context",
          "TARGET_BRANCH = {target-branch} # as per discussion context",
          "PLAN_CONTENT = {plan-content} # as per discussion context",
          "WORKTREE_PATH = ../worktree-$PLAN_ID-scope"
        ]
      },
      {
        "op": "update-tracker",
        "tracker-github": "gh issue edit $PLAN_ID --body \"$PLAN_CONTENT\" --remove-label to-scope --add-label to-slice",
        "tracker-local-gitignored": [
          "mkdir -p \"$TRACKER_PATH/$PLAN_ID $PLAN_TITLE\"",
          "printf '%s' \"$PLAN_CONTENT\" > \"$TRACKER_PATH/$PLAN_ID $PLAN_TITLE/[to-slice] plan.md\""
        ],
        "tracker-local-committed": [
          "worktree-enter.sh --fork-from $TRACKER_BRANCH --path $WORKTREE_PATH-tracker",
          "mkdir -p \"$TRACKER_PATH/$PLAN_ID $PLAN_TITLE\"",
          "printf '%s' \"$PLAN_CONTENT\" > \"$TRACKER_PATH/$PLAN_ID $PLAN_TITLE/[to-slice] plan.md\"",
          "commit.sh --branch $TRACKER_BRANCH -m \"scope: persist plan for $PLAN_ID $PLAN_TITLE\"",
          "worktree-exit.sh --path $WORKTREE_PATH-tracker"
        ]
      }
    ]
  },
  "phases": {
    "slice.md": [
      {
        "op": "set-variables",
        "sh": [
          "ISSUE_ID = {issue-id} # pre-existing and passed or generate",
          "TRACKER_PATH = {from config.md} # set only for local tracker",
          "TRACKER_BRANCH = {from config.md} # set only for local-tracker-committed"
        ]
      },
      {
        "op": "fetch-context",
        "tracker-github": "gh issue view $ISSUE_ID --json body,title,labels",
        "tracker-local": "$TRACKER_PATH/$ISSUE_ID*/[to-slice] plan.md"
      },
      {
        "op": "set-variables",
        "sh": [
          "PLAN_ID = $ISSUE_ID",
          "PLAN_TITLE = {from plan body}",
          "BASE_BRANCH = {from plan body}",
          "TARGET_BRANCH = {from plan body}",
          "WORKTREE_PATH = ../worktree-$PLAN_ID-slice"
        ]
      },
      {
        "op": "enter",
        "cmd": "worktree-enter.sh --fork-from $TARGET_BRANCH --path $WORKTREE_PATH"
      },
      {
        "op": "create-remote-branch",
        "cmd": "git push -u origin $TARGET_BRANCH",
        "if": "multi-slice"
      },
      { "op": "phase-specific" },
      {
        "op": "set-variables",
        "sh": [
          "SLICE_NAME = {per slice, e.g. 001-auth-endpoint}",
          "SLICE_NUMBER = {sub-issue number (github) or file name (local)}"
        ]
      },
      {
        "op": "update-tracker",
        "tracker-github": "gh issue edit $PLAN_ID --remove-label to-slice --add-label in-progress",
        "tracker-local-gitignored": "mv \"$TRACKER_PATH/$PLAN_ID $PLAN_TITLE/[to-slice] plan.md\" \"$TRACKER_PATH/$PLAN_ID $PLAN_TITLE/[in-progress] plan.md\"",
        "tracker-local-committed": [
          "worktree-enter.sh --fork-from $TRACKER_BRANCH --path $WORKTREE_PATH-tracker",
          "mv \"$TRACKER_PATH/$PLAN_ID $PLAN_TITLE/[to-slice] plan.md\" \"$TRACKER_PATH/$PLAN_ID $PLAN_TITLE/[in-progress] plan.md\"",
          "commit.sh --branch $TRACKER_BRANCH -m \"slice: create slices for $PLAN_ID $PLAN_TITLE\"",
          "worktree-exit.sh --path $WORKTREE_PATH-tracker"
        ]
      },
      {
        "op": "exit",
        "cmd": "worktree-exit.sh --path $WORKTREE_PATH"
      }
    ],
    "implement.md": [
      {
        "op": "set-variables",
        "sh": [
          "ISSUE_ID = {issue-id} # pre-existing and passed or generate",
          "TRACKER_PATH = {from config.md} # set only for local tracker",
          "TRACKER_BRANCH = {from config.md} # set only for local-tracker-committed"
        ]
      },
      {
        "op": "fetch-context",
        "tracker-github": "gh issue view $ISSUE_ID --json body,title,labels",
        "tracker-local": "$TRACKER_PATH/*/slices/[to-implement] $ISSUE_ID*.md"
      },
      {
        "op": "set-variables",
        "sh": [
          "SLICE_NAME = {from slice body}",
          "SLICE_NUMBER = $ISSUE_ID",
          "PLAN_ID = {from slice/plan body}",
          "PLAN_TITLE = {from slice/plan body}",
          "BASE_BRANCH = {from slice/plan body}",
          "TARGET_BRANCH = {from slice/plan body}",
          "SLICE_BRANCH = {PR branch, e.g. feat/001-auth-endpoint}",
          "WORKTREE_PATH = ../worktree-$SLICE_NAME-implement"
        ]
      },
      {
        "op": "enter",
        "cmd": "worktree-enter.sh --fork-from $TARGET_BRANCH --path $WORKTREE_PATH"
      },
      { "op": "phase-specific" },
      {
        "op": "commit-code",
        "cmd": "commit.sh --branch $SLICE_BRANCH -m \"$SLICE_NAME: implementation\""
      },
      {
        "op": "pr-create",
        "cmd": "gh pr create --base $TARGET_BRANCH --title \"$SLICE_NAME\" --body \"$REPORT\""
      },
      {
        "op": "set-variables",
        "sh": ["PR_NUMBER = {from gh pr create output}"]
      },
      {
        "op": "update-tracker",
        "tracker-github": "gh issue edit $SLICE_NUMBER --remove-label to-implement --add-label to-inspect",
        "tracker-local-gitignored": "mv \"$TRACKER_PATH/$PLAN_ID $PLAN_TITLE/slices/[to-implement] $SLICE_NAME.md\" \"$TRACKER_PATH/$PLAN_ID $PLAN_TITLE/slices/[to-inspect] $SLICE_NAME.md\"",
        "tracker-local-committed": [
          "worktree-enter.sh --fork-from $TRACKER_BRANCH --path $WORKTREE_PATH-tracker",
          "mv \"$TRACKER_PATH/$PLAN_ID $PLAN_TITLE/slices/[to-implement] $SLICE_NAME.md\" \"$TRACKER_PATH/$PLAN_ID $PLAN_TITLE/slices/[to-inspect] $SLICE_NAME.md\"",
          "commit.sh --branch $TRACKER_BRANCH -m \"implement: update tracker for $SLICE_NAME\"",
          "worktree-exit.sh --path $WORKTREE_PATH-tracker"
        ]
      },
      {
        "op": "exit",
        "cmd": "worktree-exit.sh --path $WORKTREE_PATH"
      }
    ],
    "inspect.md": [
      {
        "op": "set-variables",
        "sh": [
          "ISSUE_ID = {issue-id} # pre-existing and passed or generate",
          "TRACKER_PATH = {from config.md} # set only for local tracker",
